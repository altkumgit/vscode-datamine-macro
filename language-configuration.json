{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["'", "'"],
        ["\"", "\""]
    ],
    "wordPattern": "(!?[A-Za-z][A-Za-z0-9_]*|\\$[A-Za-z0-9_]+#|&[A-Za-z0-9_]+|\\*[A-Za-z0-9_]+|@[A-Za-z0-9_]+)",
    "indentationRules": {
        "increaseIndentPattern": "^\\s*!START\\b|^\\s*!IF\\b|^\\s*!ELSE\\b|^\\s*!ELSEIF\\b",
        "decreaseIndentPattern": "^\\s*!END\\b|^\\s*!ENDIF\\b|^\\s*!ELSE\\b|^\\s*!ELSEIF\\b"
    }
}
